generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  GARAGE_OWNER
  ADMIN
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  CNG
  OTHER
}

enum OtpPurpose {
  SIGNUP
  RESET_PASSWORD
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum LocationSource {
  GPS
  MANUAL
}

enum MediaType {
  IMAGE
  VIDEO
}

model User {
  id              String  @id @default(uuid())
  name            String
  email           String  @unique
  phone           String  @unique
  password        String
  role            Role    @default(CUSTOMER)
  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)
  isOnboarded     Boolean @default(false)
  isActive        Boolean @default(true)

  customerProfile CustomerProfile?
  otps            Otp[]
  vehicles        Vehicle[]
  locations       CustomerLocation[]
  bookings        Booking[]
  reviews         Review[]
  complaints      Complaint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Otp {
  id        String     @id @default(uuid())
  userId    String
  otpHash   String
  purpose   OtpPurpose @default(SIGNUP)
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model CustomerProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  avatarUrl      String?
  avatarPublicId String?
  address        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id                 String   @id @default(uuid())
  userId             String
  brand              String
  model              String
  year               Int
  fuelType           FuelType
  registrationNumber String?
  isDefault          Boolean  @default(false)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CustomerLocation {
  id        String         @id @default(uuid())
  userId    String
  latitude  Float
  longitude Float
  address   String?
  source    LocationSource @default(GPS)
  isDefault Boolean        @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Garage {
  id          String  @id @default(uuid())
  name        String
  description String?
  phone       String
  whatsappNo  String?
  email       String?

  address   String
  city      String
  area      String
  latitude  Float
  longitude Float

  isVerified  Boolean @default(false)
  isActive    Boolean @default(true)
  ratingAvg   Float   @default(0)
  ratingCount Int     @default(0)

  openingTime String?
  closingTime String?

  services GarageService[]
  slots    GarageSlot[]
  bookings Booking[]
  reviews  Review[]

  images GarageImage[]
  videos GarageVideo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([area])
  @@index([latitude, longitude])
}

model GarageImage {
  id       String @id @default(uuid())
  garageId String
  imageUrl String
  publicId String
  order    Int    @default(0)

  isThumbnail Boolean @default(false)

  garage Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([garageId])
  @@index([isThumbnail])
}

model GarageVideo {
  id       String @id @default(uuid())
  garageId String
  videoUrl String
  publicId String
  order    Int    @default(0)

  durationSeconds Int?
  sizeBytes       Int?

  garage Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([garageId])
}

model ServiceCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String  @id @default(uuid())
  categoryId  String
  name        String
  description String?
  isActive    Boolean @default(true)

  category       ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  garageServices GarageService[]
  bookings       Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model GarageService {
  id        String  @id @default(uuid())
  garageId  String
  serviceId String
  price     Int?
  duration  Int?
  isActive  Boolean @default(true)

  garage  Garage  @relation(fields: [garageId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([garageId, serviceId])
  @@index([garageId])
  @@index([serviceId])
}

model GarageSlot {
  id          String   @id @default(uuid())
  garageId    String
  date        DateTime
  startTime   String
  endTime     String
  capacity    Int      @default(1)
  bookedCount Int      @default(0)
  isActive    Boolean  @default(true)

  garage   Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([garageId])
  @@index([date])
}

model Booking {
  id        String  @id @default(uuid())
  userId    String
  vehicleId String
  garageId  String
  serviceId String
  slotId    String?

  bookingCode String @unique

  scheduledDate DateTime
  startTime     String
  endTime       String?

  status BookingStatus @default(PENDING_PAYMENT)

  customerNote String?
  garageNote   String?

  handlingFee Int @default(99)

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  garage  Garage      @relation(fields: [garageId], references: [id], onDelete: Restrict)
  service Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  slot    GarageSlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)

  payment    Payment?
  review     Review?
  complaints Complaint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([garageId])
  @@index([vehicleId])
  @@index([status])
}

model Payment {
  id        String @id @default(uuid())
  bookingId String @unique

  amount   Int           @default(99)
  currency String        @default("INR")
  status   PaymentStatus @default(CREATED)

  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        String @id @default(uuid())
  userId    String
  garageId  String
  bookingId String @unique

  rating  Int
  comment String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  garage  Garage  @relation(fields: [garageId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([garageId])
}

model Complaint {
  id        String  @id @default(uuid())
  userId    String
  bookingId String?

  title       String
  description String
  status      ComplaintStatus @default(OPEN)

  adminReply String?
  resolvedAt DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  images ComplaintImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([bookingId])
  @@index([status])
}

model ComplaintImage {
  id          String @id @default(uuid())
  complaintId String
  imageUrl    String
  publicId    String
  order       Int    @default(0)

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([complaintId])
}

DATABASE_URL=""

PORT=5000
NODE_ENV=development

JWT_SECRET="your_jwt_secret_here"
JWT_EXPIRES_IN="7d"

RESEND_API_KEY=""
EMAIL_FROM=""
EMAIL_OTP_DELIVERY="log"
CONTACT_INBOX="rovauto.offical@gmail.com"

FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

SMS_PROVIDER="fast2sms_quick"
FAST2SMS_API_KEY=""

# Optional fallback for custom SMS providers.
SMS_PROVIDER_URL=""
SMS_PROVIDER_TOKEN=""
SMS_SENDER_ID="ROVAUTO"

CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
CASHFREE_ENV="sandbox"
CASHFREE_NOTIFY_URL=""
CLIENT_URL="https://your-frontend-domain.com"
FRONTEND_URL="https://your-frontend-domain.com"
# Garage request broadcast radius in kilometers.
GARAGE_BROADCAST_RADIUS_KM=15

# Website path opened by garage owners from WhatsApp booking request links.
GARAGE_REQUEST_ACCEPT_PATH="/garage/requests"

# Optional generic WhatsApp provider integration. If empty, backend logs WhatsApp messages.
WHATSAPP_PROVIDER_URL=""
WHATSAPP_PROVIDER_TOKEN=""
WHATSAPP_SENDER_ID=""

# Temporary service range logic: upper estimate = current/base price + this amount.
SERVICE_PRICE_RANGE_DELTA=500
# Garage search expires if no garage accepts within this many seconds.
GARAGE_SEARCH_TIMEOUT_SECONDS=120

# Handover OTP validity for garage vehicle handover verification.
HANDOVER_OTP_TTL_MINUTES=30
# OpenStreetMap Nominatim geocoder for manual address -> latitude/longitude.
GEOCODER_PROVIDER="nominatim"
NOMINATIM_USER_AGENT="Rovauto/1.0 (your-email@example.com)"
NOMINATIM_TIMEOUT_MS=8000

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  GARAGE_OWNER
  ADMIN
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  CNG
  OTHER
}

enum OtpPurpose {
  SIGNUP
  RESET_PASSWORD
}

enum BookingStatus {
  PENDING_PAYMENT
  SEARCHING_GARAGE
  GARAGE_ASSIGNED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum LocationSource {
  GPS
  MANUAL
}

enum MediaType {
  IMAGE
  VIDEO
}

enum WalletType {
  CUSTOMER
  GARAGE
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  RECHARGE
  REFUND
  CASHBACK
  BOOKING_PAYMENT
  BOOKING_REFUND
  GARAGE_ACCEPT_FEE
  SOS_DEDUCTION
}

enum WalletTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BroadcastStatus {
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum RequestType {
  NORMAL
  SOS
}

model User {
  id              String  @id @default(uuid())
  name            String
  email           String  @unique
  phone           String  @unique
  password        String
  role            Role    @default(CUSTOMER)
  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)
  isOnboarded     Boolean @default(false)
  isActive        Boolean @default(true)

  customerProfile CustomerProfile?
  otps            Otp[]
  vehicles        Vehicle[]
  locations       CustomerLocation[]
  bookings        Booking[]
  reviews         Review[]
  complaints      Complaint[]

  ownedGarages Garage[]

  wallet             Wallet?
  walletTransactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Otp {
  id        String     @id @default(uuid())
  userId    String
  otpHash   String
  purpose   OtpPurpose @default(SIGNUP)
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model CustomerProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  avatarUrl      String?
  avatarPublicId String?
  address        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id                 String   @id @default(uuid())
  userId             String
  brand              String
  model              String
  year               Int
  fuelType           FuelType
  registrationNumber String?
  isDefault          Boolean  @default(false)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CustomerLocation {
  id        String         @id @default(uuid())
  userId    String
  latitude  Float
  longitude Float
  address   String?
  source    LocationSource @default(GPS)
  isDefault Boolean        @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([latitude, longitude])
}

model Garage {
  id      String  @id @default(uuid())
  ownerId String?

  name        String
  description String?
  phone       String
  whatsappNo  String?
  email       String?

  address   String
  city      String
  area      String
  latitude  Float
  longitude Float

  isVerified  Boolean @default(false)
  isActive    Boolean @default(true)
  ratingAvg   Float   @default(0)
  ratingCount Int     @default(0)

  openingTime String?
  closingTime String?

  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  services   GarageService[]
  bookings   Booking[]
  reviews    Review[]
  broadcasts GarageBroadcastRequest[]

  images GarageImage[]
  videos GarageVideo[]

  wallet             GarageWallet?
  walletTransactions GarageWalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([city])
  @@index([area])
  @@index([latitude, longitude])
}

model GarageImage {
  id       String @id @default(uuid())
  garageId String
  imageUrl String
  publicId String
  order    Int    @default(0)

  isThumbnail Boolean @default(false)

  garage Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([garageId])
  @@index([isThumbnail])
}

model GarageVideo {
  id       String @id @default(uuid())
  garageId String
  videoUrl String
  publicId String
  order    Int    @default(0)

  durationSeconds Int?
  sizeBytes       Int?

  garage Garage @relation(fields: [garageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([garageId])
}

model ServiceCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id         String @id @default(uuid())
  categoryId String

  name        String
  description String?
  basePrice   Int?
  minPrice    Int?
  maxPrice    Int?
  durationMin Int?
  isActive    Boolean @default(true)

  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  media          ServiceMedia[]
  garageServices GarageService[]
  bookingItems   BookingService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([isActive])
}

model ServiceMedia {
  id        String    @id @default(uuid())
  serviceId String
  mediaType MediaType

  url      String
  publicId String
  order    Int    @default(0)

  isThumbnail     Boolean @default(false)
  durationSeconds Int?
  sizeBytes       Int?

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId])
  @@index([mediaType])
  @@index([isThumbnail])
}

model GarageService {
  id        String @id @default(uuid())
  garageId  String
  serviceId String

  price    Int?
  duration Int?
  isActive Boolean @default(true)

  garage  Garage  @relation(fields: [garageId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([garageId, serviceId])
  @@index([garageId])
  @@index([serviceId])
  @@index([isActive])
}

model Booking {
  id        String @id @default(uuid())
  userId    String
  vehicleId String

  garageId String?

  bookingCode String @unique

  scheduledDate DateTime?
  startTime     String?
  endTime       String?

  requestType RequestType   @default(NORMAL)
  status      BookingStatus @default(PENDING_PAYMENT)

  customerLatitude  Float?
  customerLongitude Float?
  customerAddress   String?

  customerNote String?
  garageNote   String?

  handlingFee Int @default(99)

  totalServiceAmount Int @default(0)
  walletAmountUsed   Int @default(0)
  payableAmount      Int @default(99)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  garage  Garage? @relation(fields: [garageId], references: [id], onDelete: SetNull)

  services   BookingService[]
  payment    Payment?
  review     Review?
  complaints Complaint[]
  broadcasts GarageBroadcastRequest[]

  acceptedAt DateTime?
  expiredAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([garageId])
  @@index([vehicleId])
  @@index([status])
  @@index([requestType])
}

model BookingService {
  id        String @id @default(uuid())
  bookingId String
  serviceId String

  quantity       Int  @default(1)
  estimatedPrice Int?
  finalPrice     Int?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookingId, serviceId])
  @@index([bookingId])
  @@index([serviceId])
}

model GarageBroadcastRequest {
  id        String @id @default(uuid())
  bookingId String
  garageId  String

  status BroadcastStatus @default(SENT)

  sentAt     DateTime  @default(now())
  acceptedAt DateTime?
  rejectedAt DateTime?
  expiredAt  DateTime?

  garageResponseNote String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  garage  Garage  @relation(fields: [garageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookingId, garageId])
  @@index([bookingId])
  @@index([garageId])
  @@index([status])
}

model Payment {
  id        String @id @default(uuid())
  bookingId String @unique

  amount   Int
  currency String        @default("INR")
  status   PaymentStatus @default(CREATED)

  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  walletAmountUsed Int @default(0)
  upiAmountPaid    Int @default(0)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wallet {
  id     String     @id @default(uuid())
  userId String     @unique
  type   WalletType @default(CUSTOMER)

  balance Int @default(0)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id       String @id @default(uuid())
  walletId String
  userId   String

  type   WalletTransactionType
  status WalletTransactionStatus @default(SUCCESS)

  amount       Int
  balanceAfter Int?

  description String?

  razorpayOrderId   String?
  razorpayPaymentId String?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([userId])
  @@index([type])
  @@index([status])
}

model GarageWallet {
  id       String @id @default(uuid())
  garageId String @unique

  balance Int @default(0)

  garage       Garage                    @relation(fields: [garageId], references: [id], onDelete: Cascade)
  transactions GarageWalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GarageWalletTransaction {
  id             String @id @default(uuid())
  garageWalletId String
  garageId       String

  type   WalletTransactionType
  status WalletTransactionStatus @default(SUCCESS)

  amount       Int
  balanceAfter Int?

  description String?

  razorpayOrderId   String?
  razorpayPaymentId String?

  garageWallet GarageWallet @relation(fields: [garageWalletId], references: [id], onDelete: Cascade)
  garage       Garage       @relation(fields: [garageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([garageWalletId])
  @@index([garageId])
  @@index([type])
  @@index([status])
}

model Review {
  id        String @id @default(uuid())
  userId    String
  garageId  String
  bookingId String @unique

  rating  Int
  comment String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  garage  Garage  @relation(fields: [garageId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([garageId])
}

model Complaint {
  id        String  @id @default(uuid())
  userId    String
  bookingId String?

  title       String
  description String
  status      ComplaintStatus @default(OPEN)

  adminReply String?
  resolvedAt DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  images ComplaintImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([bookingId])
  @@index([status])
}

model ComplaintImage {
  id          String @id @default(uuid())
  complaintId String
  imageUrl    String
  publicId    String
  order       Int    @default(0)

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([complaintId])
}

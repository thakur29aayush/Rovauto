generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(uuid())
  name               String
  email              String
  phone              String?
  password           String
  role               Role                @default(CUSTOMER)
  isEmailVerified    Boolean             @default(false)
  isPhoneVerified    Boolean             @default(false)
  isOnboarded        Boolean             @default(false)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bookings           Booking[]
  complaints         Complaint[]
  locations          CustomerLocation[]
  customerProfile    CustomerProfile?
  ownedGarages       Garage[]
  notifications      Notification[]
  otps               Otp[]
  reviews            Review[]
  vehicles           Vehicle[]
  wallet             Wallet?
  walletTransactions WalletTransaction[]

  @@unique([email, role])
  @@unique([phone, role])
  @@index([email])
  @@index([phone])
}

model Otp {
  id        String     @id @default(uuid())
  userId    String
  otpHash   String
  purpose   OtpPurpose @default(SIGNUP)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PendingSignup {
  id              String   @id @default(uuid())
  name            String
  email           String
  phone           String
  passwordHash    String
  role            Role     @default(CUSTOMER)
  isEmailVerified Boolean  @default(false)
  isPhoneVerified Boolean  @default(false)
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([email, role])
  @@unique([phone, role])
  @@index([email])
  @@index([phone])
  @@index([expiresAt])
  @@map("pending_signups")
}

model EmailOtp {
  id        String   @id @default(uuid())
  email     String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([expiresAt])
  @@map("email_otps")
}

model PhoneOtp {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([expiresAt])
  @@map("phone_otps")
}

model CustomerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  avatarUrl      String?
  address        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  avatarPublicId String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id                 String    @id @default(uuid())
  userId             String
  brand              String
  model              String
  year               Int
  fuelType           FuelType
  registrationNumber String?
  isDefault          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  bookings           Booking[]
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CustomerLocation {
  id        String         @id @default(uuid())
  userId    String
  latitude  Float
  longitude Float
  address   String?
  source    LocationSource @default(GPS)
  isDefault Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([latitude, longitude])
}

model Garage {
  id                 String                    @id @default(uuid())
  name               String
  description        String?
  phone              String
  whatsappNo         String?
  email              String?
  address            String
  city               String
  area               String
  latitude           Float
  longitude          Float
  workingRadiusKm    Int                       @default(15)
  isVerified         Boolean                   @default(false)
  isActive           Boolean                   @default(true)
  ratingAvg          Float                     @default(0)
  ratingCount        Int                       @default(0)
  openingTime        String?
  closingTime        String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  ownerId            String?
  applicationId      String?                   @unique
  bookings           Booking[]
  inspectionImages   BookingInspectionImage[]
  owner              User?                     @relation(fields: [ownerId], references: [id])
  broadcasts         GarageBroadcastRequest[]
  images             GarageImage[]
  services           GarageService[]
  videos             GarageVideo[]
  wallet             GarageWallet?
  walletTransactions GarageWalletTransaction[]
  reviews            Review[]

  @@index([ownerId])
  @@index([city])
  @@index([area])
  @@index([latitude, longitude])
}

model GarageImage {
  id          String   @id @default(uuid())
  garageId    String
  imageUrl    String
  publicId    String
  order       Int      @default(0)
  isThumbnail Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  garage      Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([garageId])
  @@index([isThumbnail])
}

model GarageVideo {
  id              String   @id @default(uuid())
  garageId        String
  videoUrl        String
  publicId        String
  order           Int      @default(0)
  durationSeconds Int?
  sizeBytes       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  garage          Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([garageId])
}

model ServiceCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  services    Service[]
}

model Service {
  id              String                  @id @default(uuid())
  categoryId      String
  name            String
  description     String?
  isActive        Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  basePrice       Int?
  maxPrice        Int?
  minPrice        Int?
  bookingItems    BookingService[]
  cityPriceRanges CityServicePriceRange[]
  garageServices  GarageService[]
  category        ServiceCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  media           ServiceMedia[]

  @@index([categoryId])
  @@index([isActive])
}

model ServiceMedia {
  id              String    @id @default(uuid())
  serviceId       String
  mediaType       MediaType
  url             String
  publicId        String
  order           Int       @default(0)
  isThumbnail     Boolean   @default(false)
  durationSeconds Int?
  sizeBytes       Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  service         Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([mediaType])
  @@index([isThumbnail])
}

model GarageService {
  id        String   @id @default(uuid())
  garageId  String
  serviceId String
  price     Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([garageId, serviceId])
  @@index([garageId])
  @@index([serviceId])
  @@index([isActive])
}

model CityServicePriceRange {
  id           String    @id @default(uuid())
  city         String
  serviceId    String
  vehicleBrand String?
  vehicleModel String?
  fuelType     FuelType?
  minPrice     Int
  maxPrice     Int
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  service      Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([serviceId])
  @@index([vehicleBrand])
  @@index([vehicleModel])
  @@index([fuelType])
  @@index([isActive])
}

model City {
  id             String   @id @default(uuid())
  name           String
  normalizedName String   @unique
  state          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@index([name])
}

model Booking {
  id                    String                   @id @default(uuid())
  userId                String
  vehicleId             String
  garageId              String?
  bookingCode           String                   @unique
  scheduledDate         DateTime?
  startTime             String?
  endTime               String?
  status                BookingStatus            @default(PENDING_PAYMENT)
  customerNote          String?
  garageNote            String?
  handlingFee           Int                      @default(99)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  acceptedAt            DateTime?
  customerAddress       String?
  customerLatitude      Float?
  customerLongitude     Float?
  expiredAt             DateTime?
  payableAmount         Int                      @default(99)
  requestType           RequestType              @default(NORMAL)
  totalServiceAmount    Int                      @default(0)
  walletAmountUsed      Int                      @default(0)
  totalServiceMaxAmount Int                      @default(0)
  searchExpiresAt       DateTime?
  handoverOtpHash       String?
  handoverOtpExpiresAt  DateTime?
  handoverOtpVerifiedAt DateTime?
  deliveredAt           DateTime?
  customerAcceptedAt    DateTime?
  garage                Garage?                  @relation(fields: [garageId], references: [id])
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle               Vehicle                  @relation(fields: [vehicleId], references: [id])
  inspectionImages      BookingInspectionImage[]
  services              BookingService[]
  complaints            Complaint[]
  broadcasts            GarageBroadcastRequest[]
  payment               Payment?
  review                Review?

  @@index([userId])
  @@index([garageId])
  @@index([vehicleId])
  @@index([status])
  @@index([requestType])
}

model BookingInspectionImage {
  id        String            @id @default(uuid())
  bookingId String
  garageId  String
  phase     BookingPhotoPhase
  imageUrl  String
  publicId  String
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  booking   Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  garage    Garage            @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@unique([bookingId, phase, order])
  @@index([bookingId])
  @@index([garageId])
  @@index([phase])
}

model BookingService {
  id                String   @id @default(uuid())
  bookingId         String
  serviceId         String
  quantity          Int      @default(1)
  estimatedPrice    Int?
  finalPrice        Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  estimatedMinPrice Int?
  estimatedMaxPrice Int?
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service           Service  @relation(fields: [serviceId], references: [id])

  @@unique([bookingId, serviceId])
  @@index([bookingId])
  @@index([serviceId])
}

model GarageBroadcastRequest {
  id                 String          @id @default(uuid())
  bookingId          String
  garageId           String
  status             BroadcastStatus @default(SENT)
  sentAt             DateTime        @default(now())
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  expiredAt          DateTime?
  garageResponseNote String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  booking            Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  garage             Garage          @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@unique([bookingId, garageId])
  @@index([bookingId])
  @@index([garageId])
  @@index([status])
}

model Payment {
  id                       String        @id @default(uuid())
  bookingId                String        @unique
  amount                   Int
  currency                 String        @default("INR")
  status                   PaymentStatus @default(CREATED)
  cashfreeOrderId          String?       @unique
  cashfreePaymentId        String?       @unique
  cashfreePaymentSessionId String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  upiAmountPaid            Int           @default(0)
  walletAmountUsed         Int           @default(0)
  booking                  Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Wallet {
  id           String              @id @default(uuid())
  userId       String              @unique
  type         WalletType          @default(CUSTOMER)
  balance      Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id                String                  @id @default(uuid())
  walletId          String
  userId            String
  type              WalletTransactionType
  status            WalletTransactionStatus @default(SUCCESS)
  amount            Int
  balanceAfter      Int?
  description       String?
  cashfreeOrderId   String?
  cashfreePaymentId String?
  createdAt         DateTime                @default(now())
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet            Wallet                  @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([userId])
  @@index([type])
  @@index([status])
}

model GarageWallet {
  id           String                    @id @default(uuid())
  garageId     String                    @unique
  balance      Int                       @default(0)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  garage       Garage                    @relation(fields: [garageId], references: [id], onDelete: Cascade)
  transactions GarageWalletTransaction[]
}

model GarageWalletTransaction {
  id                String                  @id @default(uuid())
  garageWalletId    String
  garageId          String
  type              WalletTransactionType
  status            WalletTransactionStatus @default(SUCCESS)
  amount            Int
  balanceAfter      Int?
  description       String?
  cashfreeOrderId   String?
  cashfreePaymentId String?
  createdAt         DateTime                @default(now())
  garage            Garage                  @relation(fields: [garageId], references: [id], onDelete: Cascade)
  garageWallet      GarageWallet            @relation(fields: [garageWalletId], references: [id], onDelete: Cascade)

  @@index([garageWalletId])
  @@index([garageId])
  @@index([type])
  @@index([status])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  garageId  String
  bookingId String   @unique
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([garageId])
}

model VehicleBrand {
  id        String         @id @default(uuid())
  name      String         @unique
  logoUrl   String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  models    VehicleModel[]
}

model VehicleModel {
  id        String       @id @default(uuid())
  brandId   String
  name      String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  brand     VehicleBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, name])
  @@index([brandId])
}

model Complaint {
  id          String           @id @default(uuid())
  userId      String
  bookingId   String?
  title       String
  description String
  status      ComplaintStatus  @default(OPEN)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  adminReply  String?
  resolvedAt  DateTime?
  booking     Booking?         @relation(fields: [bookingId], references: [id])
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  images      ComplaintImage[]

  @@index([userId])
  @@index([bookingId])
  @@index([status])
}

model ComplaintImage {
  id          String    @id @default(uuid())
  complaintId String
  imageUrl    String
  publicId    String
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String?
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model GarageApplication {
  id               String                   @id @default(uuid())
  ownerName        String
  email            String
  phone            String
  garageName       String
  description      String?
  address          String
  city             String
  area             String
  latitude         Float?
  longitude        Float?
  workingRadiusKm  Int                      @default(15)
  status           GarageApplicationStatus  @default(PENDING)
  adminNote        String?
  reviewedAt       DateTime?
  approvedGarageId String?                  @unique
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  images           GarageApplicationImage[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([createdAt])
}

model GarageApplicationImage {
  id            String            @id @default(uuid())
  applicationId String
  imageUrl      String
  publicId      String
  order         Int               @default(0)
  isThumbnail   Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  application   GarageApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([isThumbnail])
}

enum GarageApplicationStatus {
  PENDING
  CHANGES_REQUESTED
  APPROVED
  DENIED
}

enum Role {
  CUSTOMER
  GARAGE_OWNER
  ADMIN
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  CNG
  OTHER
}

enum OtpPurpose {
  SIGNUP
  RESET_PASSWORD
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  SEARCHING_GARAGE
  GARAGE_ASSIGNED
  EXPIRED
}

enum NotificationType {
  BOOKING
  PAYMENT
  WARRANTY
  PROMOTION
  SYSTEM
  SOS
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum LocationSource {
  GPS
  MANUAL
}

enum MediaType {
  IMAGE
  VIDEO
}

enum WalletType {
  CUSTOMER
  GARAGE
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  RECHARGE
  REFUND
  CASHBACK
  BOOKING_PAYMENT
  BOOKING_REFUND
  GARAGE_ACCEPT_FEE
  SOS_DEDUCTION
}

enum WalletTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BroadcastStatus {
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum RequestType {
  NORMAL
  SOS
}

enum BookingPhotoPhase {
  PICKUP
  DELIVERY
}
